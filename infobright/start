#!/bin/bash
set -eu

# Idempotent: if the container is running and responsive, do nothing.
if sudo docker inspect -f '{{.State.Running}}' mysql_ib 2>/dev/null | grep -q true; then
    if sudo docker run --rm --network host mysql:5 \
        mysql --host 127.0.0.1 --port 5029 --user=root --password=mypass \
        -e "SELECT 1" >/dev/null 2>&1; then
        exit 0
    fi
fi

sudo docker start mysql_ib
