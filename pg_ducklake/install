#!/bin/bash
set -eu

CONTAINER_NAME=${CONTAINER_NAME:-pgduck}
PGDUCK_IMAGE=${PGDUCK_IMAGE:-pgducklake/pgducklake:18-main}

sudo apt-get update -y
sudo apt-get install -y docker.io postgresql-client

sudo docker pull "$PGDUCK_IMAGE"

if sudo docker ps -a --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
    sudo docker rm -f "$CONTAINER_NAME" >/dev/null
fi

sudo docker run -d \
    --name "$CONTAINER_NAME" \
    -p 5432:5432 \
    -e POSTGRES_PASSWORD=duckdb \
    "$PGDUCK_IMAGE"
