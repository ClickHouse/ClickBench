#!/bin/bash
# Reads a SQL query from stdin, runs it via clickhouse-local against the S3
# datalake table defined in create.sql. Stdout: query result. Stderr: query
# runtime in fractional seconds on the last line. Exit non-zero on error.
set -e

query=$(cat)
# Clear shared filesystem cache between queries so timings are cold.
rm -rf /dev/shm/clickhouse/* 2>/dev/null || true

./clickhouse local --path . --time --filesystem_cache_name cache \
    --query="$(cat create.sql); ${query}"
