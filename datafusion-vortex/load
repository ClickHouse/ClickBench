#!/bin/bash
set -e

# clickbench fetches Parquet and converts to .vortex on first invocation.
# Run query 0 once with the bundled queries.sql to trigger conversion;
# the wrapping driver will time the load via wall clock around this script.
export PATH="$PWD/vortex/target/release:$PATH"

clickbench -i 1 \
    --targets datafusion:vortex \
    --display-format gh-json \
    --queries-file ./queries.sql \
    --flavor single \
    --hide-progress-bar \
    -q 0 >/dev/null

sync
