#!/bin/bash
set -e

# Idempotent: blow away any prior per-column files.
rm -rf cols
mkdir -p cols

# Ensure pyarrow is available for the preprocessor.
sudo apt-get install -y python3-pip python3-pyarrow >/dev/null 2>&1 \
    || pip3 install --quiet pyarrow

# Convert hits.parquet to per-column binary files. The preprocessor is
# Python only because BQN doesn't have a parquet reader; the queries
# themselves are pure BQN (see queries.bqn).
python3 prep.py hits.parquet cols

rm -f hits.parquet
sync
