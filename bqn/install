#!/bin/bash
# Build CBQN, the fastest BQN implementation, from source.
# https://github.com/dzaima/CBQN
set -e

if command -v BQN >/dev/null 2>&1; then
    exit 0
fi

sudo apt-get update
# libffi-dev so CBQN's optional FFI module compiles; the stock build
# pulls in the headers unconditionally and fails the o3 target without
# them on a fresh Ubuntu image.
sudo apt-get install -y build-essential gcc git libffi-dev python3-pip

# pyarrow / numpy via pip — Ubuntu 24.04 doesn't ship python3-pyarrow
# and PEP 668 blocks unscoped pip writes to the system Python without
# --break-system-packages.
sudo pip3 install --break-system-packages --quiet pyarrow numpy

tmp=$(mktemp -d)
git clone --depth=1 https://github.com/dzaima/CBQN.git "$tmp/CBQN"
(
    cd "$tmp/CBQN"
    make o3 -j"$(nproc)"
)
sudo cp "$tmp/CBQN/BQN" /usr/local/bin/BQN
rm -rf "$tmp"
