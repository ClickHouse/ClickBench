#!/bin/bash
# Reads a SQL query from stdin, POSTs it to the LocustDB HTTP daemon,
# prints the JSON response to stdout and the wall-clock elapsed time
# (fractional seconds) on the last line of stderr.
#
# The bench harness's contract is "stderr's last line = seconds". LocustDB
# does return per-query "stats" in the response body (rows scanned, etc.)
# but does not include wall-clock query time, so we time the round-trip
# ourselves.
set -e

query=$(cat)

# Compact JSON body — `jq -Rn` quotes the SQL safely without shell quoting
# hazards (the ClickBench queries embed single quotes, percent signs, and
# backslashes).
body=$(jq -Rn --arg q "$query" '{query: $q}')

start_t=$(date +%s.%N)
out=$(curl -sS --max-time 600 -X POST \
    -H 'Content-Type: application/json' \
    --data-binary "$body" \
    http://127.0.0.1:8123/query) && status=0 || status=$?
end_t=$(date +%s.%N)

if [ "$status" -ne 0 ]; then
    printf 'curl exit %s\n' "$status" >&2
    exit "$status"
fi

# LocustDB returns HTTP 200 with a JSON error payload when the query
# fails (unsupported feature, bad column, panic-caught-by-actix, ...).
# Detect that and surface as a non-zero exit so the harness records the
# try as `null`.
if printf '%s' "$out" | jq -e '.error // empty' >/dev/null 2>&1; then
    printf '%s\n' "$out" >&2
    exit 1
fi

printf '%s\n' "$out"
awk -v s="$start_t" -v e="$end_t" 'BEGIN { printf "%.6f\n", e - s }' >&2
