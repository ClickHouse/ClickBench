#!/bin/bash
# Reads a SQL query from stdin, runs it via ysqlsh against yugabytedb.
# Stdout: query result.
# Stderr: query runtime in fractional seconds on the last line.
# Exit non-zero on error.
set -e

query=$(cat)

raw=$(./yugabyte/bin/ysqlsh -U yugabyte -d test -v ON_ERROR_STOP=1 -t \
    -c '\timing' -c "$query" 2>&1) && exit_code=0 || exit_code=$?

if [ "$exit_code" -ne 0 ] || printf '%s\n' "$raw" | grep -qE '^(ERROR|FATAL):|ysqlsh: error'; then
    printf '%s\n' "$raw" >&2
    exit 1
fi

printf '%s\n' "$raw" | grep -v '^Time:'

ms=$(printf '%s\n' "$raw" | grep -oP 'Time:\s*\K[0-9.]+' | tail -n1)
if [ -z "$ms" ]; then
    echo "no Time: in ysqlsh output" >&2
    exit 1
fi
awk -v m="$ms" 'BEGIN { printf "%.3f\n", m / 1000 }' >&2
