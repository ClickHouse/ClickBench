#!/bin/bash
set -eu

sudo mariadb -e "DROP DATABASE IF EXISTS test"
sudo mariadb -e "CREATE DATABASE test"
sudo mariadb test < create.sql

# Stream-load in chunks of 10000 lines (the original benchmark approach).
split -l 10000 --filter="sudo mariadb test -e \"SET sql_log_bin = 0; LOAD DATA LOCAL INFILE '/dev/stdin' INTO TABLE hits;\"" hits.tsv

rm -f hits.tsv
sync
