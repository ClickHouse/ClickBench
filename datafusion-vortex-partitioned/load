#!/bin/bash
set -e

# query_bench fetches Parquet and converts to .vortex on first invocation.
export PATH="$PWD/vortex/target/release:$PATH"

query_bench clickbench -i 1 \
    --targets datafusion:vortex \
    --display-format gh-json \
    --queries-file ./queries.sql \
    --flavor partitioned \
    --hide-progress-bar \
    -q 0 >/dev/null

sync
