(count hits)
(count (select {from: hits where: (!= AdvEngineID 0)}))
(table [a b c] (list (list (sum (at hits 'AdvEngineID))) (list (count hits)) (list (avg (at hits 'ResolutionWidth)))))
(avg (at hits 'UserID))
(count (distinct (at hits 'UserID)))
(count (distinct (at hits 'SearchPhrase)))
(table [a b] (list (list (min (at hits 'EventDate))) (list (max (at hits 'EventDate)))))
(select {AdvEngineID: AdvEngineID c: (count AdvEngineID) from: hits where: (!= AdvEngineID 0) by: AdvEngineID desc: c take: 10})
(select {RegionID: RegionID u: (count (distinct UserID)) from: hits by: RegionID desc: u take: 10})
(select {RegionID: RegionID s: (sum AdvEngineID) c: (count RegionID) a: (avg ResolutionWidth) u: (count (distinct UserID)) from: hits by: RegionID desc: c take: 10})
(select {MobilePhoneModel: MobilePhoneModel u: (count (distinct UserID)) from: hits where: (!= MobilePhoneModel "") by: MobilePhoneModel desc: u take: 10})
(select {u: (count UserID) from: (select {from: hits where: (!= MobilePhoneModel "") by: {MobilePhone: MobilePhone MobilePhoneModel: MobilePhoneModel UserID: UserID}}) by: {MobilePhone: MobilePhone MobilePhoneModel: MobilePhoneModel} desc: u take: 10})
(select {SearchPhrase: SearchPhrase c: (count SearchPhrase) from: hits where: (!= SearchPhrase "") by: SearchPhrase desc: c take: 10})
(select {SearchPhrase: SearchPhrase u: (count (distinct UserID)) from: hits where: (!= SearchPhrase "") by: SearchPhrase desc: u take: 10})
(select {c: (count SearchPhrase) from: hits where: (!= SearchPhrase "") by: {SearchEngineID: SearchEngineID SearchPhrase: SearchPhrase} desc: c take: 10})
(select {UserID: UserID c: (count UserID) from: hits by: UserID desc: c take: 10})
(select {c: (count UserID) from: hits by: {UserID: UserID SearchPhrase: SearchPhrase} desc: c take: 10})
(select {c: (count UserID) from: hits by: {UserID: UserID SearchPhrase: SearchPhrase} take: 10})
(select {c: (count UserID) from: hits by: {UserID: UserID m: (minute EventTime) SearchPhrase: SearchPhrase} desc: c take: 10})
(select {UserID: UserID from: hits where: (== UserID 435090932899640449)})
(count (select {from: hits where: (like URL (concat "*" (concat "goo" (concat "gle" "*"))))}))
(select {SearchPhrase: SearchPhrase u: (count UserID) c: (count SearchPhrase) from: hits where: (and (like URL "*google*") (!= SearchPhrase "")) by: SearchPhrase desc: c take: 10})
(select {SearchPhrase: SearchPhrase u: (count UserID) t: (count Title) c: (count SearchPhrase) d: (count (distinct UserID)) from: hits where: (and (like Title "*Google*") (not (like URL "*.google.*")) (!= SearchPhrase "")) by: SearchPhrase desc: c take: 10})
(select {from: hits where: (like URL (concat "*" (concat "goo" (concat "gle" "*")))) asc: EventTime take: 10})
(at (select {from: hits where: (!= SearchPhrase "") asc: EventTime take: 10}) 'SearchPhrase)
(at (select {from: hits where: (!= SearchPhrase "") asc: SearchPhrase take: 10}) 'SearchPhrase)
(at (select {from: hits where: (!= SearchPhrase "") asc: [EventTime SearchPhrase] take: 10}) 'SearchPhrase)
(select {from: (select {CounterID: CounterID l: (avg (strlen URL)) c: (count CounterID) from: hits where: (!= URL "") by: CounterID}) where: (> c 100000) desc: l take: 25})
(select {from: (select {k: Referer l: (avg (strlen Referer)) c: (count Referer) r: (count Referer) from: hits where: (!= Referer "") by: Referer}) where: (> c 100000) desc: l take: 25})
