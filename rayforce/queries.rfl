(select {c: (count ClientIP) s: (sum IsRefresh) a: (avg ResolutionWidth) from: hits where: (!= SearchPhrase "") by: {SearchEngineID: SearchEngineID ClientIP: ClientIP} desc: c take: 10})
(select {c: (count ClientIP) s: (sum IsRefresh) a: (avg ResolutionWidth) from: hits where: (!= SearchPhrase "") by: {WatchID: WatchID ClientIP: ClientIP} desc: c take: 10})
(select {c: (count ClientIP) s: (sum IsRefresh) a: (avg ResolutionWidth) from: hits by: {WatchID: WatchID ClientIP: ClientIP} desc: c take: 10})
(select {URL: URL c: (count URL) from: hits by: URL desc: c take: 10})
(select {one: 1 URL: URL c: (count URL) from: hits by: URL desc: c take: 10})
(select {c: (count ClientIP) from: hits by: {ClientIP: ClientIP c1: (- ClientIP 1) c2: (- ClientIP 2) c3: (- ClientIP 3)} desc: c take: 10})
(select {URL: URL PageViews: (count URL) from: hits where: (and (== CounterID 62) (>= EventDate 2013.07.01) (<= EventDate 2013.07.31) (== DontCountHits 0) (== IsRefresh 0) (!= URL "")) by: URL desc: PageViews take: 10})
(select {Title: Title PageViews: (count Title) from: hits where: (and (== CounterID 62) (>= EventDate 2013.07.01) (<= EventDate 2013.07.31) (== DontCountHits 0) (== IsRefresh 0) (!= Title "")) by: Title desc: PageViews take: 10})
(take (select {URL: URL PageViews: (count URL) from: hits where: (and (== CounterID 62) (>= EventDate 2013.07.01) (<= EventDate 2013.07.31) (== IsRefresh 0) (!= IsLink 0) (== IsDownload 0)) by: URL desc: PageViews take: 1010}) -10)
(take (select {PageViews: (count URL) from: hits where: (and (== CounterID 62) (>= EventDate 2013.07.01) (<= EventDate 2013.07.31) (== IsRefresh 0)) by: {TraficSourceID: TraficSourceID SearchEngineID: SearchEngineID AdvEngineID: AdvEngineID Src: (if (and (== SearchEngineID 0) (== AdvEngineID 0)) Referer "") Dst: URL} desc: PageViews take: 1010}) -10)
(take (select {PageViews: (count URLHash) from: hits where: (and (== CounterID 62) (>= EventDate 2013.07.01) (<= EventDate 2013.07.31) (== IsRefresh 0) (in TraficSourceID [-1 6]) (== RefererHash 3594120000172545465)) by: {URLHash: URLHash EventDate: EventDate} desc: PageViews take: 110}) -10)
(take (select {PageViews: (count WindowClientWidth) from: hits where: (and (== CounterID 62) (>= EventDate 2013.07.01) (<= EventDate 2013.07.31) (== IsRefresh 0) (== DontCountHits 0) (== URLHash 2868770270353813622)) by: {WindowClientWidth: WindowClientWidth WindowClientHeight: WindowClientHeight} desc: PageViews take: 10010}) -10)
(take (select {PageViews: (count EventTime) from: hits where: (and (== CounterID 62) (>= EventDate 2013.07.14) (<= EventDate 2013.07.15) (== IsRefresh 0) (== DontCountHits 0)) by: {M: (xbar EventTime 60000000000)} asc: M take: 1010}) -10)
