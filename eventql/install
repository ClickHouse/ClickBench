#!/bin/bash
set -e

# Install Docker + Python (the loader uses aiohttp for parallel
# JSON-over-HTTP inserts), then build the EventQL image.

if ! command -v docker >/dev/null 2>&1; then
    sudo apt-get update -y
    sudo apt-get install -y docker.io
    sudo systemctl enable --now docker
fi

if ! command -v python3 >/dev/null 2>&1; then
    sudo apt-get update -y
    sudo apt-get install -y python3 python3-pip
fi
# aiohttp ships in Ubuntu's `python3-aiohttp` deb on 22.04+; pip3 fallback
# for older images.
if ! python3 -c 'import aiohttp' 2>/dev/null; then
    sudo apt-get install -y python3-aiohttp || sudo pip3 install --break-system-packages aiohttp
fi

# Bind-mount target for the standalone server's data dir; ./data-size
# reads it from here without docker exec.
sudo mkdir -p /var/lib/clickbench-eventql
sudo chmod 777 /var/lib/clickbench-eventql

# Idempotent image build.
if ! sudo docker image inspect clickbench-eventql >/dev/null 2>&1; then
    sudo docker build -t clickbench-eventql .
fi
