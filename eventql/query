#!/bin/bash
# Reads a SQL query from stdin, POSTs it to /api/v1/sql, prints the JSON
# response to stdout and the wall-clock elapsed time to stderr's last
# line. EventQL's response JSON does not contain server-side timings,
# so we measure the round-trip ourselves.
set -e

query=$(cat)
body=$(jq -Rn --arg q "$query" '{database:"clickbench", query:$q}')

start_t=$(date +%s.%N)
out=$(curl -sS --max-time 600 -X POST \
    -H 'Content-Type: application/json' \
    --data-binary "$body" \
    http://127.0.0.1:9175/api/v1/sql) && status=0 || status=$?
end_t=$(date +%s.%N)

if [ "$status" -ne 0 ]; then
    printf 'curl exit %s\n' "$status" >&2
    exit "$status"
fi

# EventQL returns HTTP 200 with {"error":"..."} for SQL/runtime errors
# (unsupported feature, bad column, etc.). Detect it and exit non-zero
# so the harness records `null` for the try.
if printf '%s' "$out" | jq -e '.error // empty' >/dev/null 2>&1; then
    printf '%s\n' "$out" >&2
    exit 1
fi

printf '%s\n' "$out"
awk -v s="$start_t" -v e="$end_t" 'BEGIN { printf "%.6f\n", e - s }' >&2
