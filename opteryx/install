#!/bin/bash
set -e

sudo apt-get update -y
sudo apt-get install -y software-properties-common
sudo add-apt-repository -y ppa:deadsnakes/ppa
sudo apt-get update -y
sudo apt-get install -y python3.11 python3.11-venv git wget build-essential python3.11-dev

if [ ! -d "$HOME/opteryx_venv" ]; then
    python3.11 -m venv "$HOME/opteryx_venv"
fi

"$HOME/opteryx_venv/bin/python" -m pip install --upgrade pip
# 0.26.1 only ships x86_64 wheels, so arm64 hosts (c8g.*) fell through
# to sdist where the build failed at "opteryx/third_party/abseil/
# containers.pyx doesn't match any files". 0.26.8 publishes
# manylinux2014_aarch64 wheels for cp310-cp313, which fixes arm64
# without changing anything for x86_64.
"$HOME/opteryx_venv/bin/python" -m pip install --upgrade opteryx==0.26.8
