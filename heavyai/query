#!/bin/bash
# Reads a SQL query from stdin, runs it via heavysql.
# Stdout: query result.
# Stderr: query runtime in fractional seconds on the last line (parsed from
# heavysql's "Total time: <ms> ms" footer).
# Exit non-zero on error.
set -e

query=$(cat)

raw=$(/opt/heavyai/bin/heavysql -t -p HyperInteractive <<< "$query" 2>&1) && exit_code=0 || exit_code=$?

if [ "$exit_code" -ne 0 ] || printf '%s\n' "$raw" | grep -qiE '^Exception|^Error'; then
    printf '%s\n' "$raw" >&2
    exit 1
fi

printf '%s\n' "$raw"

ms=$(printf '%s\n' "$raw" | grep -oP 'Total time:\s*\K[0-9]+(?=\s*ms)' | tail -n1)

if [ -z "$ms" ]; then
    echo "no timing in heavysql output" >&2
    exit 1
fi

awk -v m="$ms" 'BEGIN { printf "%.3f\n", m / 1000 }' >&2
