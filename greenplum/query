#!/bin/bash
# Reads a SQL query from stdin, runs it via psql against the postgres DB.
# Stdout: query result.
# Stderr: query runtime in fractional seconds on the last line.
# Exit non-zero on error.
set -e

# shellcheck disable=SC1091
source /opt/greenplum-db-*/greenplum_path.sh
export MASTER_DATA_DIRECTORY=${MASTER_DATA_DIRECTORY:-/gpmaster/gpsne-1/}

query=$(cat)

out=$(printf '\\timing\n%s\n' "$query" | psql -d postgres -t 2>&1)
status=$?

if printf '%s\n' "$out" | grep -q '^ERROR\|psql: error'; then
    printf '%s\n' "$out" >&2
    exit 1
fi

printf '%s\n' "$out" | grep -v '^Time:'

time_ms=$(printf '%s\n' "$out" | grep -oP 'Time:\s+\K[0-9]+\.[0-9]+' | tail -n1)
if [ -z "$time_ms" ]; then
    echo "no timing in psql output" >&2
    exit 1
fi
awk -v ms="$time_ms" 'BEGIN { printf "%.3f\n", ms / 1000 }' >&2

exit "$status"
