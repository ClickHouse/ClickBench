#!/bin/bash
set -eu

# Drop and recreate to make idempotent.
sudo monetdb stop test 2>/dev/null || true
sudo monetdb destroy -f test 2>/dev/null || true
sudo monetdb create test
sudo monetdb release test

chmod 777 ~ hits.tsv

# Drive mclient non-interactively. The old query.expect wrapper waited
# on an interactive "password:" prompt that never fires when mclient
# picks credentials from ~/.monetdb (which the install script stamps
# with user=monetdb / password=monetdb). Feed SQL via stdin; auth
# comes from /root/.monetdb (HOME=root in the agent's systemd unit).
# We don't pass -P because the bundled mclient build doesn't have
# that flag — passing -P dumped --help and broke the load entirely.
mclient -h 127.0.0.1 -u monetdb -d test < create.sql
echo "COPY INTO hits FROM '$(pwd)/hits.tsv' USING DELIMITERS '\\t';" |
    mclient -h 127.0.0.1 -u monetdb -d test

rm -f hits.tsv
sync
