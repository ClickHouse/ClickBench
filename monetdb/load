#!/bin/bash
set -eu

# Drop and recreate to make idempotent.
sudo monetdb stop test 2>/dev/null || true
sudo monetdb destroy -f test 2>/dev/null || true
sudo monetdb create test
sudo monetdb release test

chmod 777 ~ hits.tsv

# Drive mclient non-interactively. The old query.expect wrapper spawned
# mclient with no -P and waited on an interactive "password:" prompt;
# under certain mclient builds the prompt never fires (auth comes from
# ~/.monetdb), expect times out, and the whole load step fails.
# Pass credentials with -P and feed SQL via stdin.
mclient -h 127.0.0.1 -u monetdb -P monetdb -d test < create.sql
echo "COPY INTO hits FROM '$(pwd)/hits.tsv' USING DELIMITERS '\\t';" |
    mclient -h 127.0.0.1 -u monetdb -P monetdb -d test

rm -f hits.tsv
sync
