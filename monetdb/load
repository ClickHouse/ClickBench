#!/bin/bash
set -eu

# Drop and recreate to make idempotent.
sudo monetdb stop test 2>/dev/null || true
sudo monetdb destroy -f test 2>/dev/null || true
sudo monetdb create test
sudo monetdb release test

chmod 777 ~ hits.tsv

# Drive mclient non-interactively. The bundled noble build uses the
# long-form `--password=...`; `-P` isn't recognized and makes mclient
# dump --help. Passing the password inline avoids depending on
# whether $HOME/.monetdb is actually read in the agent's environment.
mclient -h 127.0.0.1 -u monetdb --password=monetdb -d test < create.sql
echo "COPY INTO hits FROM '$(pwd)/hits.tsv' USING DELIMITERS '\\t';" |
    mclient -h 127.0.0.1 -u monetdb --password=monetdb -d test

rm -f hits.tsv
sync
