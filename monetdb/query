#!/bin/bash
# Reads a SQL query from stdin, runs it via mclient.
# Stdout: query result.
# Stderr: query runtime in fractional seconds on the last line (parsed
# from mclient's `\t clock` output: "clk: <ms> ms" or "clk: <s> s").
# Exit non-zero on error.
set -e

query=$(cat)

raw=$( (
    printf '\\t clock\n'
    printf '%s' "$query"
    printf ';\n'
) | mclient -h 127.0.0.1 -d test 2>&1 ) && exit_code=0 || exit_code=$?

# mclient may print errors but exit 0; sniff for the canonical markers.
if [ "$exit_code" -ne 0 ] || printf '%s\n' "$raw" | grep -qE '^!|sql:.*error'; then
    printf '%s\n' "$raw" >&2
    exit 1
fi

printf '%s\n' "$raw"

# Parse the LAST `clk:` line into seconds.
timing=$(printf '%s\n' "$raw" | grep -E '^clk:' | tail -n1)
if [ -z "$timing" ]; then
    echo "no clk timing in monetdb output" >&2
    exit 1
fi

awk -v s="$timing" 'BEGIN {
    n = split(s, a, " ")
    val = a[2]; unit = a[3]
    if (unit ~ /ms/) { printf "%.3f\n", val / 1000 }
    else if (unit ~ /s/) { printf "%.3f\n", val }
    else { printf "%.3f\n", val }
}' >&2
