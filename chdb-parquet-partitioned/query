#!/bin/bash
# Reads a SQL query from stdin, runs it via chdb against the partitioned
# parquet files in CWD.
# Stdout: query result.
# Stderr: query runtime in fractional seconds on the last line.
set -e

# shellcheck disable=SC1091
source myenv/bin/activate

# Stage stdin into a temp file: `python3 - <<'PY'` already consumes stdin to
# read the program, so sys.stdin.read() inside the heredoc returns "".
query_file=$(mktemp)
trap 'rm -f "$query_file"' EXIT
cat > "$query_file"

python3 - "$query_file" <<'PY'
import sys
import timeit
import chdb

with open(sys.argv[1]) as f:
    query = f.read()

conn = chdb.connect()

start = timeit.default_timer()
try:
    res = conn.query(query, "CSV")
    out = str(res)
    end = timeit.default_timer()
    if out:
        sys.stdout.write(out)
        if not out.endswith("\n"):
            sys.stdout.write("\n")
finally:
    conn.close()

print(f"{end - start:.3f}", file=sys.stderr)
PY
